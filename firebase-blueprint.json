{
  "entities": {
    "BankBalance": {
      "title": "Bank Balance",
      "description": "Snapshots of bank account balances.",
      "type": "object",
      "properties": {
        "bankName": { "type": "string" },
        "accountName": { "type": "string" },
        "balance": { "type": "number" },
        "currency": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "userId": { "type": "string" }
      },
      "required": ["bankName", "accountName", "balance", "currency", "date", "userId"]
    },
    "Receivable": {
      "title": "Receivable",
      "description": "Accounts Receivable ledger entry.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "invoiceDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "invoiceAmount": { "type": "number" },
        "amountOutstanding": { "type": "number" },
        "paymentTerms": { "type": "string" },
        "daysOutstanding": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["customerName", "invoiceNumber", "invoiceAmount", "amountOutstanding", "userId"]
    },
    "Payable": {
      "title": "Payable",
      "description": "Accounts Payable ledger entry.",
      "type": "object",
      "properties": {
        "vendorName": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "invoiceDate": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "invoiceAmount": { "type": "number" },
        "amountOutstanding": { "type": "number" },
        "paymentTerms": { "type": "string" },
        "daysOutstanding": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["vendorName", "invoiceNumber", "invoiceAmount", "amountOutstanding", "userId"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User specific settings.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "companyName": { "type": "string" }
      },
      "required": ["userId", "email"]
    }
  },
  "firestore": {
    "/bankBalances/{id}": {
      "schema": "BankBalance",
      "description": "User's bank balances."
    },
    "/receivables/{id}": {
      "schema": "Receivable",
      "description": "User's accounts receivable."
    },
    "/payables/{id}": {
      "schema": "Payable",
      "description": "User's accounts payable."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile information."
    }
  }
}
