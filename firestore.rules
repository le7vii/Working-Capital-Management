rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: transactions
    // Fields:
    //   - type: string (payable/receivable)
    //   - amount: number
    //   - dueDate: string (ISO 8601)
    //   - status: string (pending/paid/overdue)
    //   - description: string
    //   - counterparty: string
    //   - category: string
    //   - userId: string (owner)
    //   - createdAt: string
    //   - updatedAt: string
    //
    // Collection: users
    // Fields:
    //   - companyName: string
    //   - currency: string
    //   - email: string
    //   - userId: string
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidTransaction(data) {
      return data.type in ['payable', 'receivable'] &&
             data.amount is number && data.amount >= 0 &&
             data.dueDate is string &&
             data.status in ['pending', 'paid', 'overdue'] &&
             data.userId == request.auth.uid &&
             data.keys().hasAll(['type', 'amount', 'dueDate', 'status', 'userId']);
    }

    function isValidUser(data) {
      return data.userId == request.auth.uid &&
             data.email is string &&
             data.keys().hasAll(['userId', 'email']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidTransaction(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
