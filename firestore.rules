rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: bankBalances
    // Fields: bankName, accountName, balance, currency, date, userId
    //
    // Collection: receivables
    // Fields: customerName, invoiceNumber, invoiceDate, dueDate, invoiceAmount, amountOutstanding, paymentTerms, daysOutstanding, userId
    //
    // Collection: payables
    // Fields: vendorName, invoiceNumber, invoiceDate, dueDate, invoiceAmount, amountOutstanding, paymentTerms, daysOutstanding, userId
    //
    // Collection: users
    // Fields: userId, email, companyName
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidBankBalance(data) {
      let requiredFields = ['bankName', 'accountName', 'balance', 'currency', 'date', 'userId'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields) &&
             data.userId == request.auth.uid &&
             data.bankName is string &&
             data.accountName is string &&
             data.balance is number &&
             data.currency is string &&
             data.date is string;
    }

    function isValidReceivable(data) {
      let requiredFields = ['customerName', 'invoiceNumber', 'invoiceDate', 'dueDate', 'invoiceAmount', 'amountOutstanding', 'paymentTerms', 'daysOutstanding', 'userId'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields) &&
             data.userId == request.auth.uid &&
             data.customerName is string &&
             data.invoiceNumber is string &&
             data.invoiceDate is string &&
             data.dueDate is string &&
             data.invoiceAmount is number &&
             data.amountOutstanding is number &&
             data.paymentTerms is string &&
             data.daysOutstanding is number;
    }

    function isValidPayable(data) {
      let requiredFields = ['vendorName', 'invoiceNumber', 'invoiceDate', 'dueDate', 'invoiceAmount', 'amountOutstanding', 'paymentTerms', 'daysOutstanding', 'userId'];
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(requiredFields) &&
             data.userId == request.auth.uid &&
             data.vendorName is string &&
             data.invoiceNumber is string &&
             data.invoiceDate is string &&
             data.dueDate is string &&
             data.invoiceAmount is number &&
             data.amountOutstanding is number &&
             data.paymentTerms is string &&
             data.daysOutstanding is number;
    }

    function isValidUser(data) {
      let allowedFields = ['userId', 'email', 'companyName'];
      return data.keys().hasAll(['userId', 'email']) &&
             data.keys().hasOnly(allowedFields) &&
             data.userId == request.auth.uid &&
             data.email is string;
    }

    match /bankBalances/{id} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidBankBalance(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidBankBalance(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /receivables/{id} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidReceivable(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidReceivable(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /payables/{id} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidPayable(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidPayable(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
